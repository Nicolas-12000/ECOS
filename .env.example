ENV=dev
DEBUG=true

# ── Groq (LLM para RAG) ────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Supabase (opcional — dejar vacío si no se usa) ──
